# ── OpenRouter (main model – final answer generation and HyDE) ────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ── Fast model (query expansion, compression, grounding, RAPTOR, QA cache) ────
# Defaults to the same provider/model as above.
# Recommended: Groq (free tier – 14,400 req/day, no CoT leakage):
#   1. Sign up at https://console.groq.com → API Keys → Create key
#   2. Uncomment and fill in the three lines below:
#FAST_MODEL_API_KEY=gsk_...
#FAST_MODEL_BASE_URL=https://api.groq.com/openai/v1
#OPENROUTER_FAST_MODEL=llama-3.1-8b-instant
# Other good Groq models: llama-3.3-70b-versatile, gemma2-9b-it, mixtral-8x7b-32768
OPENROUTER_FAST_MODEL=openai/gpt-oss-120b:free

# ── Embeddings (sentence-transformers, local) ──────────────────────────────────
# Any HuggingFace sentence-transformers model. EMBEDDING_DIM must match output.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── Qdrant vector store ────────────────────────────────────────────────────────
# Leave QDRANT_URL blank for in-memory mode (data lost on restart).
# Set to http://localhost:6333 when running: docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=
QDRANT_COLLECTION=rag_children
QDRANT_CACHE_COLLECTION=rag_cache
QDRANT_RAPTOR_COLLECTION=rag_raptor

# ── Chunking ──────────────────────────────────────────────────────────────────
PARENT_CHUNK_TOKENS=800     # parent chunk size stored for LLM context
CHILD_CHUNK_TOKENS=200      # child chunk size used for search
CHUNK_OVERLAP_TOKENS=32     # token overlap between consecutive chunks

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_SEARCH=25             # candidates per index before RRF fusion
TOP_K_RERANK=8              # top-N after ColBERT / cross-encoder rerank
TOP_K_PARENTS=4             # final parent chunks sent to LLM
RRF_K=60                    # RRF constant (higher = gentler rank weighting)

# ── Multi-query expansion ──────────────────────────────────────────────────────
# Expansion fires only when the first pass returns fewer than MULTI_QUERY_MIN_HITS.
# Avoids an LLM call on clear queries, saving ~300-500 ms per request.
MULTI_QUERY_ENABLED=true
MULTI_QUERY_COUNT=3
MULTI_QUERY_MIN_HITS=8

# ── MMR (Maximal Marginal Relevance) ──────────────────────────────────────────
# Reorders final parent contexts to balance relevance vs. diversity.
# MMR_LAMBDA=1.0 → pure relevance order; 0.0 → pure diversity.
MMR_ENABLED=true
MMR_LAMBDA=0.7

# ── Contextual compression ────────────────────────────────────────────────────
# Fast model extracts only the sentences relevant to the query from each parent chunk.
# Reduces LLM context size ~60 % and lowers hallucination rate.
COMPRESSION_ENABLED=true

# ── Self-RAG grounding check ──────────────────────────────────────────────────
# After generation, fast model scores how well the answer is grounded in context.
# Result is emitted as a {"type":"grounding","score":0.9,...} SSE event.
SELF_RAG_ENABLED=true

# ── ColBERT ───────────────────────────────────────────────────────────────────
COLBERT_MODEL=colbert-ir/colbertv2.0
COLBERT_INDEX_PATH=./colbert_index

# ── RAPTOR tree ────────────────────────────────────────────────────────────────
RAPTOR_CLUSTER_SIZE=5       # target documents per cluster at each level
RAPTOR_MAX_LEVELS=3         # maximum recursion depth (0=children, N=doc root)

# ── Semantic cache ─────────────────────────────────────────────────────────────
# Queries with cosine similarity >= CACHE_THRESHOLD return the cached answer
# instantly (~50 ms) without hitting the LLM.
CACHE_THRESHOLD=0.92

# ── Generation ────────────────────────────────────────────────────────────────
MAX_ANSWER_TOKENS=1024      # default max tokens for generated answers

# ── Security ──────────────────────────────────────────────────────────────────
# API_KEY: if set, every request must include header  X-API-Key: <value>
# Leave blank to disable authentication (development only).
API_KEY=

# Maximum PDF upload size in megabytes.
MAX_FILE_SIZE_MB=50

# Rate limits (slowapi format: "N/period" where period = second/minute/hour).
RATE_LIMIT_QUERY=30/minute
RATE_LIMIT_INGEST=5/minute

# ── Persistence (required for Docker Qdrant to survive restarts) ───────────────
# Qdrant persists vectors itself. BM25, ParentStore, and DocRegistry are
# in-memory and would otherwise be lost on restart. When QDRANT_URL is set,
# these are automatically pickled to PERSIST_DIR after every ingest so the
# app recovers fully on restart without re-ingesting any documents.
PERSIST_DIR=./persist

# ── Paths ─────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
